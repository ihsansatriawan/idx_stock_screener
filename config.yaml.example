# IDX Stock Screener Configuration
# Copy this file to config.yaml and edit with your settings

google_sheets:
  enabled: true
  sheet_id: "YOUR_GOOGLE_SHEET_ID_HERE"  # From sheet URL
  credentials_path: "credentials/google_credentials.json"
  output_tab_name: "TOP_5"

universe:
  # Mode: 'dynamic' fetches from APIs, 'static' uses tickers list below
  mode: "dynamic"

  # Source priority for dynamic mode (tried in order until one succeeds)
  # Options: idx (IDX API), static (local file), config (tickers below)
  source_priority:
    - idx
    - static
    - config

  # Local file path for 'static' provider
  static_file: "data/idx_stocks.json"

  # Cache settings for dynamic mode
  cache_enabled: true
  cache_ttl_hours: 24

  # Filters (applied after fetching)
  # index_filter: "LQ45"  # Options: LQ45, IDX30, null (no filter)
  # sector_filter:        # Filter by sectors (uncomment to use)
  #   - Financial Services
  #   - Energy
  # max_stocks: 50        # Limit number of stocks (null = no limit)
  # exclude_tickers: []   # Tickers to always exclude

  # Fallback tickers (used when mode is 'static' or as last resort)
  tickers:
    - BBCA
    - BBRI
    - BMRI
    - BBNI
    - TLKM
    - ASII
    - UNVR
    - ICBP
    - INDF
    - KLBF
    - GGRM
    - HMSP
    - SMGR
    - PTBA
    - ADRO
    - ITMG
    - ANTM
    - INCO
    - MDKA
    - ESSA

data:
  period: "60d"  # 60 days lookback
  min_data_points: 40  # Minimum trading days required

technical:
  supertrend:
    period: 10
    multiplier: 3.0

  rsi:
    period: 14

  bollinger_bands:
    period: 20
    std: 2.0

  macd:
    fast: 12
    slow: 26
    signal: 9

  ema:
    periods: [20, 50]

  volume:
    sma_period: 20

institutional:
  mfi:
    period: 14

  obv:
    trend_period: 5

  ad_line:
    trend_period: 5

  # Scoring weights (total 100%)
  weights:
    mfi: 30
    volume_accumulation: 25
    obv_trend: 20
    ad_trend: 15
    price_volume_divergence: 10

screening:
  initial_filter:
    rsi_min: 40
    rsi_max: 70
    volume_ratio_min: 0.8
    require_supertrend_bullish: true
    require_above_ema20: true

  output_top_n: 5

scoring:
  weights:
    trend_strength: 35
    momentum: 25
    institutional: 25
    risk_reward: 15

risk:
  max_sl_percent: 2.0  # Maximum 2% stop loss
  min_rr_ratio: 3.0    # Minimum 1:3 risk/reward ratio
  tp_multiples: [2.0, 3.0, 4.0]  # TP1, TP2, TP3 multipliers

logging:
  level: "INFO"  # DEBUG, INFO, WARNING, ERROR
  timezone: "Asia/Jakarta"
